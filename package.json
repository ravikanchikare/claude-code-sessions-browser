{
  "name": "cc-session-viewer",
  "version": "0.1.0",
  "description": "Browse, compare, and copy transcripts of Claude Code conversation logs",
  "type": "module",
  "bin": {
    "cc-session-viewer": "build/bin/cli.js"
  },
  "scripts": {
    "dev": "tsx bin/cli.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "start": "node build/bin/cli.js",
    "export-md": "tsx scripts/export-project-sessions-md.ts",
    "list-projects": "tsx scripts/export-project-sessions-md.ts --list-projects",
    "count-tokens": "bash scripts/run-count-tokens.sh",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "build",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "session",
    "browser",
    "conversation",
    "viewer"
  ],
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "express": "^4.21.0",
    "marked": "^15.0.0",
    "open": "^10.1.0",
    "puppeteer-core": "^24.42.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
